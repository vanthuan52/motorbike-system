{
  "name": "nestjs-motorbike-system",
  "version": "0.0.1",
  "description": "Motorbike system application built on NestJs",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "vanthuan52",
    "email": "charlesdang.252@gmail.com"
  },
  "scripts": {
    "build": "NODE_ENV=production nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_ENV=development nest start",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:debug": "NODE_ENV=development nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "pm2:dev": "nest start --env development",
    "pm2:prod": "node dist/main --env production",
    "package:upgrade": "npx npm-check-updates -u",
    "package:check": "npx npm-check-updates -i",
    "generate:keys": "npx ts-node scripts/generate-keys.ts",
    "migrate:fresh": "NODE_ENV=development npm run migrate:remove && npm run migrate:seed",
    "migrate:seed": "NODE_ENV=development nestjs-command seed:role && nestjs-command seed:user && nestjs-command seed:part-type && nestjs-command seed:hiring && nestjs-command seed:store",
    "migrate:seed:care-area": "nestjs-command seed:care-area && nestjs-command seed:service-checklist",
    "migrate:remove": "NODE_ENV=development nestjs-command remove:user && nestjs-command remove:role && nestjs-command remove:part-type && nestjs-command remove:hiring  && nestjs-command remove:store && nestjs-command remove:care-area && nestjs-command remove:service-checklist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.782.0",
    "@aws-sdk/s3-request-presigner": "^3.787.0",
    "@casl/ability": "^6.7.3",
    "@faker-js/faker": "^9.6.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.5",
    "@nestjs/swagger": "^11.0.7",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.5",
    "@sentry/node": "^9.22.0",
    "@smithy/types": "^4.2.0",
    "bcryptjs": "^3.0.2",
    "cache-manager": "^6.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.8.0",
    "crypto-js": "^4.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "lodash": "^4.17.21",
    "luxon": "^3.6.1",
    "mongodb": "^6.16.0",
    "mongoose": "^8.13.2",
    "nestjs-command": "^3.1.5",
    "nestjs-i18n": "^10.5.1",
    "nestjs-pino": "^4.4.0",
    "passport-jwt": "^4.0.1",
    "path": "^0.12.7",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "response-time": "^2.3.3",
    "rotating-file-stream": "^3.2.6",
    "rxjs": "^7.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/bytes": "^3.1.5",
    "@types/compression": "^1.8.0",
    "@types/cors": "^2.8.18",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.20",
    "@types/luxon": "^3.6.2",
    "@types/ms": "^2.1.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/response-time": "^2.3.8",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint",
      "stop-only --file"
    ],
    "*.{json,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "npm": "please-use-yarn",
    "yarn": ">= 1.22.22",
    "node": ">= 20.11.0"
  }
}
