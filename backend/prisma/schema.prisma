datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

model Role {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String    @unique
  description String?
  isActive    Boolean   @default(true)
  type        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([isActive])
  @@map("roles")
}

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String?
  email           String    @unique
  username        String    @unique
  phone           String?
  password        String?
  passwordExpired DateTime?
  passwordCreated DateTime?
  passwordAttempt Int       @default(0)
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  status          String    @default("active")
  gender          String?
  photoCdnUrl     String?

  signUpDate DateTime?
  signUpFrom String?
  signUpWith String?

  lastLoginAt   DateTime?
  lastLoginFrom String?
  lastLoginWith String?
  lastSeenAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  userRoles               UserRole[]
  messages                Message[]         @relation("UserMessages")
  receivedMessages        Message[]         @relation("UserReceivedMessages")
  sessions                Session[]         @relation("UserSessions")
  sessionsRevoked         Session[]         @relation("UserRevokedSessions")
  deviceOwnerships        DeviceOwnership[] @relation("UserDeviceOwnerships")
  deviceOwnershipsRevoked DeviceOwnership[] @relation("UserDeviceOwnershipRevoked")
  verifications           Verification[]
  appointments            Appointment[]
  careRecords             CareRecord[]
  careRecordItems         CareRecordItem[]
  activityLogs            ActivityLog[]
  applicationReviews      ApplicationReview[]
  userVehicles            UserVehicle[]

  @@index([status])
  @@index(fields: [id, deletedAt])
  @@index(fields: [status, deletedAt, createdAt(sort: Desc)])
  @@index(fields: [email, deletedAt])
  @@map("users")
}

// ================================
// DOMAIN: PERMISSIONS
// ================================

model Permission {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String    @unique
  description String?
  group       String?
  action      String
  subject     String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  rolePermissions RolePermission[]

  @@index([action])
  @@index([subject])
  @@index([isActive])
  @@map("permissions")
}

// ================================
// DOMAIN: RBAC JUNCTION TABLES
// ================================

model UserRole {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  user       User      @relation(fields: [userId], references: [id])
  roleId     String    @db.ObjectId
  role       Role      @relation(fields: [roleId], references: [id])
  assignedBy String?   @db.ObjectId
  assignedAt DateTime  @default(now())
  revokedAt  DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  roleId       String     @db.ObjectId
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String     @db.ObjectId
  permission   Permission @relation(fields: [permissionId], references: [id])
  assignedBy   String?    @db.ObjectId
  assignedAt   DateTime   @default(now())

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Session {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String    @db.ObjectId
  deviceOwnershipId String    @db.ObjectId
  jti               String
  ipAddress         String
  userAgent         Json
  geoLocation       Json?
  expiredAt         DateTime
  revokedAt         DateTime?
  isRevoked         Boolean   @default(false)
  revokedById       String?   @db.ObjectId

  revokedBy       User?            @relation("UserRevokedSessions", fields: [revokedById], references: [id])
  user            User?            @relation("UserSessions", fields: [userId], references: [id])
  deviceOwnership DeviceOwnership? @relation("DeviceOwnershipSessions", fields: [deviceOwnershipId], references: [id])

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  @@unique(fields: [userId, jti])
  @@index(fields: [userId, expiredAt(sort: Desc), isRevoked])
  @@index(fields: [isRevoked, expiredAt(sort: Asc)])
  @@index(fields: [userId, deviceOwnershipId, isRevoked])
  @@index(fields: [deviceOwnershipId])
  @@index(fields: [createdAt])
  @@index(fields: [updatedAt])
  @@map("Sessions")
}

model ActivityLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  action      String
  ipAddress   String
  userAgent   Json?
  geoLocation Json?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@map("activity_logs")
}

// ================================
// DOMAIN: API MANAGEMENT
// ================================

model ApiKey {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  type      String
  name      String
  key       String    @unique
  hash      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  @@index([type])
  @@index([isActive])
  @@map("api_keys")
}

// ================================
// DOMAIN: MEDIA & FILES
// ================================

model Media {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  key           String    @unique
  filename      String
  mimeType      String
  size          Int
  extension     String
  bucket        String
  cdnUrl        String?
  completedUrl  String
  type          String    @default("other")
  purpose       String    @default("general")
  status        String    @default("active")
  accessibility String    @default("private")
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  mediaAttachments MediaAttachment[]

  @@map("media")
}

model MediaAttachment {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  attachableType String
  attachableId   String    @db.ObjectId
  mediaId        String    @db.ObjectId
  media          Media     @relation(fields: [mediaId], references: [id])
  purpose        String    @default("default")
  caption        String?
  orderBy        Int    @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  @@unique([attachableType, attachableId, mediaId, purpose])
  @@index([attachableType, attachableId])
  @@index([mediaId])
  @@index([purpose])
  @@map("media_attachments")
}

// ================================
// DOMAIN: STORE & LOCATION
// ================================

model Store {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  address     String
  workHours   String
  description String?
  slug        String    @unique
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  careRecords CareRecord[]

  @@index([status])
  @@map("store")
}

// ================================
// DOMAIN: VEHICLE MANAGEMENT
// ================================

model VehicleBrand {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  orderBy     Int    @default(0)
  country     String?
  status      String    @default("active")
  photoCdnUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  vehicleModels VehicleModel[]
  parts         Part[]

  @@index([status])
  @@map("vehicle_brands")
}

model VehicleModel {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  fullName           String?
  slug               String    @unique
  description        String?
  engineDisplacement Int?
  modelYear          Int?
  type               String    @default("unknown")
  fuelType           String    @default("unknown")
  status             String    @default("active")
  orderBy            Int    @default(0)
  yearStart          Int?
  yearEnd            Int?
  photoCdnUrl        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  vehicleBrandId String       @db.ObjectId
  vehicleBrand   VehicleBrand @relation(fields: [vehicleBrandId], references: [id])

  servicePrices ServicePrice[]
  appointments  Appointment[]
  userVehicles  UserVehicle[]

  @@index([vehicleBrandId])
  @@index([type])
  @@index([fuelType])
  @@index([status])
  @@map("vehicle_models")
}

model VehicleService {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  orderBy     Int    @default(0)
  basePrice   Int       @default(0)
  status      String    @default("active")
  photoCdnUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  serviceCategoryId String          @db.ObjectId
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id])

  servicePrices      ServicePrice[]
  appointmentIds     String[]            @db.ObjectId
  appointments       Appointment[]       @relation(fields: [appointmentIds], references: [id])
  careRecordItems    CareRecordItem[]
  careRecordServices CareRecordService[]
  checklistItems     ServiceChecklist[]

  @@index([serviceCategoryId])
  @@index([status])
  @@map("vehicle_services")
}

model ServiceCategory {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  orderBy     Int    @default(0)
  status      String    @default("active")
  photoCdnUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  vehicleServices VehicleService[]

  @@index([status])
  @@map("service_categories")
}

model ServicePrice {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  price Int    @default(0)

  vehicleServiceId String         @db.ObjectId
  vehicleService   VehicleService @relation(fields: [vehicleServiceId], references: [id])
  vehicleModelId   String         @db.ObjectId
  vehicleModel     VehicleModel   @relation(fields: [vehicleModelId], references: [id])

  dateStart DateTime  @default(now())
  dateEnd   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  @@index([vehicleServiceId, vehicleModelId])
  @@index([vehicleServiceId])
  @@index([vehicleModelId])
  @@map("service_prices")
}

model ServiceChecklist {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String    @unique
  description String?
  orderBy     Int    @default(0)
  vehicleType String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  careAreaId String   @db.ObjectId
  careArea   CareArea @relation(fields: [careAreaId], references: [id])

  vehicleServiceId     String?               @db.ObjectId
  vehicleService       VehicleService?       @relation(fields: [vehicleServiceId], references: [id])
  careRecordChecklists CareRecordChecklist[]

  @@index([careAreaId])
  @@map("service_checklists")
}

model CareArea {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  orderBy     Int    @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  serviceChecklists ServiceChecklist[]

  @@map("care_areas")
}

// ================================
// DOMAIN: PART MANAGEMENT
// ================================

model PartType {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  orderBy     Int    @default(0)
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  parts Part[]

  @@index([status])
  @@map("part_types")
}

model Part {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  status      String    @default("active")
  photoCdnUrl String?
  orderBy     Int    @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  partTypeId     String       @db.ObjectId
  partType       PartType     @relation(fields: [partTypeId], references: [id])
  vehicleBrandId String       @db.ObjectId
  vehicleBrand   VehicleBrand @relation(fields: [vehicleBrandId], references: [id])

  careRecordItems CareRecordItem[]

  @@index([partTypeId])
  @@index([vehicleBrandId])
  @@index([status])
  @@map("parts")
}

// ================================
// DOMAIN: VEHICLE OWNERSHIP
// ================================

model UserVehicle {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  modelYear          Int?
  color              String?
  licensePlateNumber String
  engineNumber       String?
  chassisNumber      String?
  photoCdnUrl        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  userId         String       @db.ObjectId
  user           User         @relation(fields: [userId], references: [id])
  vehicleModelId String       @db.ObjectId
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id])

  careRecords  CareRecord[]
  appointments Appointment[]

  @@index([userId])
  @@index([vehicleModelId])
  @@map("user_vehicles")
}

// ================================
// DOMAIN: APPOINTMENTS
// ================================

model Appointment {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  phone              String
  licensePlateNumber String?
  address            String?
  customerRequests   String[]
  note               String?
  appointmentDate    DateTime
  status             String    @default("pending")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  userId         String?      @db.ObjectId
  user           User?        @relation(fields: [userId], references: [id])
  userVehicleId  String?      @db.ObjectId
  userVehicle    UserVehicle? @relation(fields: [userVehicleId], references: [id])
  vehicleModelId String       @db.ObjectId
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id])

  careRecords       CareRecord[]
  vehicleServiceIds String[]         @db.ObjectId
  vehicleServices   VehicleService[] @relation(fields: [vehicleServiceIds], references: [id])

  @@index([userId])
  @@index([userVehicleId])
  @@index([vehicleModelId])
  @@index([status])
  @@index([phone])
  @@map("appointments")
}

// ================================
// DOMAIN: CARE RECORDS
// ================================

model CareRecord {
  id                         String    @id @default(auto()) @map("_id") @db.ObjectId
  vehicleModelName           String?
  isInitialConditionRecorded Boolean   @default(false)
  receivedAt                 DateTime? @default(now())
  confirmedByOwner           Boolean   @default(false)
  status                     String    @default("pending")
  paymentStatus              String?
  paymentMethod              String?
  totalPrice                 Float?
  deliveryDate               DateTime?
  deliveryKm                 Int?
  notes                      String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  deletedAt                  DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  appointmentId String?      @db.ObjectId
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  userVehicleId String       @db.ObjectId
  userVehicle   UserVehicle  @relation(fields: [userVehicleId], references: [id])
  technicianId  String?      @db.ObjectId
  technician    User?        @relation(fields: [technicianId], references: [id])
  storeId       String?      @db.ObjectId
  store         Store?       @relation(fields: [storeId], references: [id])

  careRecordItems     CareRecordItem[]
  careRecordServices  CareRecordService[]
  careRecordMedias    CareRecordMedia[]
  careRecordCondition CareRecordCondition?

  @@index([appointmentId])
  @@index([userVehicleId])
  @@index([technicianId])
  @@index([storeId])
  @@index([status])
  @@map("care_records")
}

model CareRecordItem {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  source          String
  itemType        String
  name            String?
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  approvedByOwner Boolean?  @default(false)
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  careRecordId     String         @db.ObjectId
  careRecord       CareRecord     @relation(fields: [careRecordId], references: [id])
  vehicleServiceId String         @db.ObjectId
  vehicleService   VehicleService @relation(fields: [vehicleServiceId], references: [id])
  partId           String?        @db.ObjectId
  part             Part?          @relation(fields: [partId], references: [id])
  technicianId     String?        @db.ObjectId
  technician       User?          @relation(fields: [technicianId], references: [id])

  @@index([careRecordId])
  @@index([vehicleServiceId])
  @@index([partId])
  @@index([technicianId])
  @@map("care_record_items")
}

model CareRecordService {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  status    String    @default("pending")
  type      String    @default("service")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  careRecordId     String          @db.ObjectId
  careRecord       CareRecord      @relation(fields: [careRecordId], references: [id])
  vehicleServiceId String?         @db.ObjectId
  vehicleService   VehicleService? @relation(fields: [vehicleServiceId], references: [id])

  careRecordChecklists CareRecordChecklist[]

  @@index([careRecordId])
  @@index([vehicleServiceId])
  @@index([status])
  @@map("care_record_services")
}

model CareRecordChecklist {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  result         String    @default("unchecked")
  status         String    @default("pending")
  note           String?
  wearPercentage Int?      @default(100)
  imageBeforeCdnUrl String?
  imageAfterCdnUrl  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  careRecordServiceId String            @db.ObjectId
  careRecordService   CareRecordService @relation(fields: [careRecordServiceId], references: [id])
  serviceChecklistId  String?           @db.ObjectId
  serviceChecklist    ServiceChecklist? @relation(fields: [serviceChecklistId], references: [id])

  @@index([careRecordServiceId])
  @@index([serviceChecklistId])
  @@map("care_record_checklist")
}

model CareRecordCondition {
  id                      String    @id @default(auto()) @map("_id") @db.ObjectId
  odoKm                   Int?
  odoKmFaulty             Boolean   @default(false)
  fuelLevelPercent        Int?
  fuelLevelFaulty         Boolean   @default(false)
  engineOilLevel          String    @default("full")
  rearviewMirrorCondition String    @default("present")
  seatCondition           String    @default("ok")
  bodyCondition           String    @default("ok")
  exhaustCoverCondition   String    @default("present")
  hasLuggageRack          Boolean   @default(false)
  hasFootMat              Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  careRecordId String     @unique @db.ObjectId
  careRecord   CareRecord @relation(fields: [careRecordId], references: [id])

  @@map("care_record_conditions")
}

model CareRecordMedia {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  cdnUrl      String?
  description String?
  stage       String
  type        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  careRecordId String     @db.ObjectId
  careRecord   CareRecord @relation(fields: [careRecordId], references: [id])

  @@index([careRecordId])
  @@map("care_record_medias")
}

// ================================
// DOMAIN: MESSAGING
// ================================

model Conversation {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  participantIds String[]  @db.ObjectId
  lastMessageId  String?   @db.ObjectId
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  messages Message[]

  @@index([participantIds])
  @@map("conversations")
}

model Message {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  messageType String    @default("text")
  timestamp   DateTime  @default(now())
  status      String    @default("sent")
  readBy      String[]  @db.ObjectId
  isUnsent    Boolean   @default(false)
  attachments Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  conversationId String       @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String       @db.ObjectId
  sender         User         @relation("UserMessages", fields: [senderId], references: [id])
  receiverId     String       @db.ObjectId
  receiver       User         @relation("UserReceivedMessages", fields: [receiverId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([timestamp])
  @@map("messages")
}

// ================================
// DOMAIN: HIRING & RECRUITMENT
// ================================

model Job {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  title               String
  slug                String
  description         String?
  requirements        String[]
  location            String
  salaryRange         String
  applicationDeadline DateTime
  category            String
  jobType             String    @default("fullTime")
  status              String    @default("draft")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  applications JobApplication[]

  @@index([status])
  @@map("jobs")
}

model JobApplication {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  phone     String
  appliedAt DateTime
  status    String    @default("pending")
  resume    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  jobId String @db.ObjectId
  job   Job @relation(fields: [jobId], references: [id])

  reviews ApplicationReview[]

  @@index([jobId])
  @@index([status])
  @@map("job_applications")
}

model ApplicationReview {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  feedback  String
  rating    Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  userId           String         @db.ObjectId
  user             User           @relation(fields: [userId], references: [id])
  jobApplicationId String         @db.ObjectId
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id])

  @@index([userId])
  @@index([jobApplicationId])
  @@map("application_reviews")
}

// ================================
// DOMAIN: DEVICE
// ================================

model Device {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  fingerprint          String
  name                 String?
  platform             String
  lastActiveAt         DateTime @default(now())
  notificationToken    String?
  notificationProvider String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId

  deviceOwnerships DeviceOwnership[] @relation("DeviceDeviceOwnerships")

  @@unique(fields: [fingerprint])
  @@unique(fields: [notificationToken])
  @@map("devices")
}

model DeviceOwnership {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  isRevoked    Boolean   @default(false)
  revokedAt    DateTime?
  revokedById  String?   @db.ObjectId
  lastActiveAt DateTime  @default(now())

  deviceId String @db.ObjectId
  userId   String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId

  revokedBy User?     @relation("UserDeviceOwnershipRevoked", fields: [revokedById], references: [id])
  device    Device    @relation("DeviceDeviceOwnerships", fields: [deviceId], references: [id])
  user      User      @relation("UserDeviceOwnerships", fields: [userId], references: [id])
  sessions  Session[] @relation("DeviceOwnershipSessions")

  @@index(fields: [deviceId, revokedAt])
  @@index(fields: [userId, revokedAt])
  @@index(fields: [deviceId, userId, revokedAt])
  @@map("device_ownerships")
}

// ================================
// DOMAIN: VERIFICATION
// ================================

model Verification {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  type             String
  to               String
  expiredAt        DateTime
  expiredInMinutes Int
  resendInMinutes  Int
  reference        String
  token            String
  hashedToken      String
  link             String?
  encryptedLink    String?
  verifiedAt       DateTime?
  isUsed           Boolean   @default(false)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId

  @@index([userId])
  @@index([type])
  @@index([reference])
  @@map("verifications")
}
