# For app
NODE_ENV=development
APP_NAME="nestjs-motorbike-system"
APP_TIMEZONE="Asia/Ho_Chi_Minh"
APP_LANGUAGE=vi
APP_ENCRYPTION_SECRET_KEY=qwerty1234567890abcdefghijklmnop

HOME_URL=https://example.id
HOME_NAME="Motorbike System"

EMAIL_NO_REPLY=noreply@mail.com
EMAIL_SUPPORT=support@mail.com
EMAIL_ADMIN=admin@mail.com

HTTP_HOST=0.0.0.0
HTTP_PORT=5300

LOGGER_ENABLE=true
LOGGER_LEVEL=debug
LOGGER_INTO_FILE=true
LOGGER_PRETTIER=true
LOGGER_AUTO=false

CORS_ALLOWED_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080,http://192.168.1.230:8080,http://192.168.1.1:8080

URL_VERSIONING_ENABLE=true
URL_VERSION=1

DATABASE_URL=mongodb://<username>:<passsword>@localhost:27017/motorbike_system?retryWrites=true&w=majority&replicaSet=rs0&directConnection=true
DATABASE_HOST=mongodb://localhost:27017
DATABASE_NAME=motorbike_system
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_DEBUG=true # True for development

AUTH_JWT_ISSUER=https://example.com
AUTH_JWT_AUDIENCE=MotorbikeSystem

AUTH_JWT_ACCESS_TOKEN_JWKS_URI=http://localhost:5301/.well-known/access-jwks.json
AUTH_JWT_ACCESS_TOKEN_KID=
AUTH_JWT_ACCESS_TOKEN_PRIVATE_KEY=
AUTH_JWT_ACCESS_TOKEN_PUBLIC_KEY=
AUTH_JWT_ACCESS_TOKEN_EXPIRED=1d

AUTH_JWT_REFRESH_TOKEN_JWKS_URI=http://localhost:5301/.well-known/refresh-jwks.json
AUTH_JWT_REFRESH_TOKEN_KID=
AUTH_JWT_REFRESH_TOKEN_PRIVATE_KEY=
AUTH_JWT_REFRESH_TOKEN_PUBLIC_KEY=
AUTH_JWT_REFRESH_TOKEN_EXPIRED=30d

AUTH_SOCIAL_GOOGLE_CLIENT_ID=
AUTH_SOCIAL_GOOGLE_CLIENT_SECRET=

AUTH_SOCIAL_APPLE_CLIENT_ID=
AUTH_SOCIAL_APPLE_SIGN_IN_CLIENT_ID=

# MinIO root credentials (admin account — docker-compose only)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# S3 Storage Configuration
# MinIO mode for development: set STORAGE_ENDPOINT to local MinIO instance
# Do not set STORAGE_ENDPOINT means we use aws s3
STORAGE_ENDPOINT=http://localhost:39000
STORAGE_FORCE_PATH_STYLE=true

AWS_S3_PUBLIC_BUCKET=app-public-files
AWS_S3_PUBLIC_CDN=
AWS_S3_PRIVATE_BUCKET=app-private-files
AWS_S3_PRIVATE_CDN=
AWS_S3_TEMP_BUCKET=app-temp-processing

AWS_S3_IAM_CREDENTIAL_KEY=app-backend-user
AWS_S3_IAM_CREDENTIAL_SECRET=changeme
AWS_S3_IAM_ARN=
AWS_S3_REGION=us-east-1

AWS_SES_IAM_CREDENTIAL_KEY=
AWS_SES_IAM_CREDENTIAL_SECRET=
AWS_SES_IAM_ARN=
AWS_SES_REGION=ap-southeast-3

CACHE_REDIS_URL=redis://localhost:6379/0

QUEUE_REDIS_URL=redis://localhost:6379/1

BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=changeme

# SENTRY
SENTRY_DSN=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=


