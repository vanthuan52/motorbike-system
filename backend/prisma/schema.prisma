datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

// ================================
// DOMAIN: USER & AUTHENTICATION
// ================================

model Role {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  type        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([isActive])
  @@index([type])
  @@map("roles")
}

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String?
  email           String    @unique
  phone           String?
  password        String?
  passwordExpired DateTime?
  passwordCreated DateTime?
  passwordAttempt Int       @default(0)
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  status          String    @default("active")
  gender          String?
  photo           Json?

  signUpDate DateTime?
  signUpFrom String?
  signUpWith String?

  lastLoginAt   DateTime?
  lastLoginFrom String?
  lastLoginWith String?

  twoFactor    Json?
  verification Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  userRoles UserRole[]

  messages         Message[]
  receivedMessages Message[]         @relation("ReceivedMessages")
  sessions         Session[]
  appointments     Appointment[]
  careRecords      CareRecord[]
  careRecordItems  CareRecordItem[]
  activityLogs     ActivityLog[]
  candidateReviews CandidateReview[]
  userVehicles     UserVehicle[]

  @@index([status])
  @@map("users")
}

// ================================
// DOMAIN: PERMISSIONS (replaces old Policy)
// ================================

model Permission {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  code        String   @unique
  description String?
  group       String
  action      String
  subject     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([group])
  @@index([action])
  @@index([subject])
  @@index([isActive])
  @@map("permissions")
}

// ================================
// DOMAIN: RBAC JUNCTION TABLES
// ================================

model UserRole {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  user       User      @relation(fields: [userId], references: [id])
  roleId     String    @db.ObjectId
  role       Role      @relation(fields: [roleId], references: [id])
  assignedBy String?   @db.ObjectId
  assignedAt DateTime  @default(now())
  revokedAt  DateTime?

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  roleId       String     @db.ObjectId
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String     @db.ObjectId
  permission   Permission @relation(fields: [permissionId], references: [id])
  assignedBy   String?    @db.ObjectId
  assignedAt   DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Session {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  jti             String?
  ip              String
  userAgent       Json?
  expiredAt       DateTime
  revokeAt        DateTime?
  status          String    @default("active")
  hostname        String?
  protocol        String?
  originalUrl     String?
  method          String?
  xForwardedFor   String?
  xForwardedHost  String?
  xForwardedPorto String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("sessions")
}

model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  action    String
  ipAddress String
  userAgent Json?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@map("activity_logs")
}

// ================================
// DOMAIN: API MANAGEMENT
// ================================

model ApiKey {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String
  name      String
  key       String   @unique
  hash      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
  @@map("api_keys")
}

// ================================
// DOMAIN: MEDIA & FILES
// ================================

model Media {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  key           String   @unique
  filename      String
  mimeType      String
  size          Int
  extension     String
  bucket        String
  cdnUrl        String?
  completedUrl  String
  type          String   @default("other")
  purpose       String   @default("general")
  status        String   @default("active")
  accessibility String   @default("private")
  createdAt     DateTime @default(now())

  @@map("media")
}

// ================================
// DOMAIN: STORE & LOCATION
// ================================

model Store {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  address     String
  workHours   String
  description String?
  slug        String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  careRecords CareRecord[]

  @@index([status])
  @@map("store")
}

// ================================
// DOMAIN: VEHICLE MANAGEMENT
// ================================

model VehicleBrand {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?
  orderBy     String   @default("0")
  country     String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicleModels VehicleModel[]
  parts         Part[]

  @@map("vehicle_brands")
}

model VehicleModel {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  fullName           String?
  slug               String    @unique
  description        String?
  engineDisplacement Int?
  modelYear          Int?
  type               String    @default("unknown")
  fuelType           String    @default("unknown")
  status             String    @default("active")
  orderBy            String    @default("0")
  yearStart          Int?
  yearEnd            Int?
  photo              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  vehicleBrandId String       @db.ObjectId
  vehicleBrand   VehicleBrand @relation(fields: [vehicleBrandId], references: [id])

  servicePrices ServicePrice[]
  appointments  Appointment[]
  userVehicles  UserVehicle[]

  @@index([vehicleBrandId])
  @@index([type])
  @@index([fuelType])
  @@index([status])
  @@map("vehicle_models")
}

model VehicleService {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  orderBy     String    @default("0")
  status      String    @default("active")
  photo       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  serviceCategoryId String          @db.ObjectId
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id])

  servicePrices      ServicePrice[]
  appointmentIds     String[]            @db.ObjectId
  appointments       Appointment[]       @relation(fields: [appointmentIds], references: [id])
  careRecordItems    CareRecordItem[]
  careRecordServices CareRecordService[]
  checklistItems     ServiceChecklist[]

  @@index([serviceCategoryId])
  @@index([status])
  @@map("vehicle_services")
}

model ServiceCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?
  orderBy     String   @default("0")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicleServices VehicleService[]

  @@index([status])
  @@map("service_categories")
}

model ServicePrice {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  price Int    @default(150000)

  vehicleServiceId String         @db.ObjectId
  vehicleService   VehicleService @relation(fields: [vehicleServiceId], references: [id])
  vehicleModelId   String         @db.ObjectId
  vehicleModel     VehicleModel   @relation(fields: [vehicleModelId], references: [id])

  dateStart DateTime  @default(now())
  dateEnd   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([vehicleServiceId])
  @@index([vehicleModelId])
  @@map("service_prices")
}

model ServiceChecklist {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String   @unique
  description String?
  orderBy     String   @default("0")
  vehicleType String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  careAreaId String   @db.ObjectId
  careArea   CareArea @relation(fields: [careAreaId], references: [id])

  vehicleServiceId     String?               @db.ObjectId
  vehicleService       VehicleService?       @relation(fields: [vehicleServiceId], references: [id])
  careRecordChecklists CareRecordChecklist[]

  @@index([careAreaId])
  @@map("service_checklists")
}

model CareArea {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  orderBy     String   @default("0")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  serviceChecklists ServiceChecklist[]

  @@map("care_areas")
}

// ================================
// DOMAIN: PART MANAGEMENT
// ================================

model PartType {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?
  orderBy     String   @default("0")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parts Part[]

  @@index([status])
  @@map("part_types")
}

model Part {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?
  status      String   @default("active")
  orderBy     String   @default("0")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partTypeId     String       @db.ObjectId
  partType       PartType     @relation(fields: [partTypeId], references: [id])
  vehicleBrandId String       @db.ObjectId
  vehicleBrand   VehicleBrand @relation(fields: [vehicleBrandId], references: [id])

  careRecordItems CareRecordItem[]

  @@index([partTypeId])
  @@index([vehicleBrandId])
  @@index([status])
  @@map("parts")
}

// ================================
// DOMAIN: VEHICLE OWNERSHIP
// ================================

model UserVehicle {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  modelYear          Int?
  color              String?
  licensePlateNumber String
  engineNumber       String?
  chassisNumber      String?
  photo              Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId         String       @db.ObjectId
  user           User         @relation(fields: [userId], references: [id])
  vehicleModelId String       @db.ObjectId
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id])

  careRecords  CareRecord[]
  appointments Appointment[]

  @@index([userId])
  @@index([vehicleModelId])
  @@map("user_vehicles")
}

// ================================
// DOMAIN: APPOINTMENTS
// ================================

model Appointment {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  phone              String
  licensePlateNumber String?
  address            String?
  customerRequests   String[]
  note               String?
  appointmentDate    DateTime
  status             String   @default("pending")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId         String?      @db.ObjectId
  user           User?        @relation(fields: [userId], references: [id])
  userVehicleId  String?      @db.ObjectId
  userVehicle    UserVehicle? @relation(fields: [userVehicleId], references: [id])
  vehicleModelId String       @db.ObjectId
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id])

  careRecords       CareRecord[]
  vehicleServiceIds String[]         @db.ObjectId
  vehicleServices   VehicleService[] @relation(fields: [vehicleServiceIds], references: [id])

  @@index([userId])
  @@index([userVehicleId])
  @@index([vehicleModelId])
  @@index([status])
  @@index([phone])
  @@map("appointments")
}

// ================================
// DOMAIN: CARE RECORDS
// ================================

model CareRecord {
  id                         String    @id @default(auto()) @map("_id") @db.ObjectId
  vehicleModelName           String?
  isInitialConditionRecorded Boolean   @default(false)
  receivedAt                 DateTime? @default(now())
  confirmedByOwner           Boolean   @default(false)
  status                     String    @default("pending")
  paymentStatus              String?
  paymentMethod              String?
  totalPrice                 Float?
  deliveryDate               DateTime?
  deliveryKm                 Int?
  notes                      String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  appointmentId String?      @db.ObjectId
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  userVehicleId String       @db.ObjectId
  userVehicle   UserVehicle  @relation(fields: [userVehicleId], references: [id])
  technicianId  String?      @db.ObjectId
  technician    User?        @relation(fields: [technicianId], references: [id])
  storeId       String?      @db.ObjectId
  store         Store?       @relation(fields: [storeId], references: [id])

  careRecordItems     CareRecordItem[]
  careRecordServices  CareRecordService[]
  careRecordMedias    CareRecordMedia[]
  careRecordCondition CareRecordCondition?

  @@index([appointmentId])
  @@index([userVehicleId])
  @@index([technicianId])
  @@index([storeId])
  @@index([status])
  @@map("care_records")
}

model CareRecordItem {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  source          String
  itemType        String
  name            String?
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  approvedByOwner Boolean?  @default(false)
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  careRecordId     String         @db.ObjectId
  careRecord       CareRecord     @relation(fields: [careRecordId], references: [id])
  vehicleServiceId String         @db.ObjectId
  vehicleService   VehicleService @relation(fields: [vehicleServiceId], references: [id])
  partId           String?        @db.ObjectId
  part             Part?          @relation(fields: [partId], references: [id])
  technicianId     String?        @db.ObjectId
  technician       User?          @relation(fields: [technicianId], references: [id])

  @@index([careRecordId])
  @@index([vehicleServiceId])
  @@index([partId])
  @@index([technicianId])
  @@map("care_record_items")
}

model CareRecordService {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  status    String   @default("pending")
  type      String   @default("service")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  careRecordId     String          @db.ObjectId
  careRecord       CareRecord      @relation(fields: [careRecordId], references: [id])
  vehicleServiceId String?         @db.ObjectId
  vehicleService   VehicleService? @relation(fields: [vehicleServiceId], references: [id])

  careRecordChecklists CareRecordChecklist[]

  @@index([careRecordId])
  @@index([vehicleServiceId])
  @@index([status])
  @@map("care_record_services")
}

model CareRecordChecklist {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  result         String   @default("unchecked")
  status         String   @default("pending")
  note           String?
  wearPercentage Int?     @default(100)
  imageBefore    String?
  imageAfter     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  careRecordServiceId String            @db.ObjectId
  careRecordService   CareRecordService @relation(fields: [careRecordServiceId], references: [id])
  serviceChecklistId  String?           @db.ObjectId
  serviceChecklist    ServiceChecklist? @relation(fields: [serviceChecklistId], references: [id])

  @@index([careRecordServiceId])
  @@index([serviceChecklistId])
  @@map("care_record_checklist")
}

model CareRecordCondition {
  id                      String    @id @default(auto()) @map("_id") @db.ObjectId
  odoKm                   Int?
  odoKmFaulty             Boolean   @default(false)
  fuelLevelPercent        Int?
  fuelLevelFaulty         Boolean   @default(false)
  engineOilLevel          String    @default("full")
  rearviewMirrorCondition String    @default("present")
  seatCondition           String    @default("ok")
  bodyCondition           String    @default("ok")
  exhaustCoverCondition   String    @default("present")
  hasLuggageRack          Boolean   @default(false)
  hasFootMat              Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  createdBy String? @db.ObjectId
  updatedBy String? @db.ObjectId
  deletedBy String? @db.ObjectId

  careRecordId String     @unique @db.ObjectId
  careRecord   CareRecord @relation(fields: [careRecordId], references: [id])

  @@map("care_record_conditions")
}

model CareRecordMedia {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  url         String?
  description String?
  stage       String
  type        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  careRecordId String     @db.ObjectId
  careRecord   CareRecord @relation(fields: [careRecordId], references: [id])

  @@index([careRecordId])
  @@map("care_record_medias")
}

// ================================
// DOMAIN: MESSAGING
// ================================

model Conversation {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  participants String[] @db.ObjectId
  lastMessage  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages Message[]

  @@unique([participants])
  @@map("conversations")
}

model Message {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  messageType String   @default("text")
  timestamp   DateTime @default(now())
  status      String   @default("sent")
  readBy      String[] @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversationId String       @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String       @db.ObjectId
  sender         User         @relation(fields: [senderId], references: [id])
  receiverId     String       @db.ObjectId
  receiver       User         @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([conversationId])
  @@map("messages")
}

// ================================
// DOMAIN: HIRING & RECRUITMENT
// ================================

model Hiring {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  title               String
  slug                String
  description         String?
  requirements        String[]
  location            String
  salaryRange         String
  applicationDeadline DateTime
  category            String
  jobType             String   @default("fullTime")
  status              String   @default("draft")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  candidates Candidate[]

  @@index([status])
  @@map("hiring")
}

model Candidate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  phone     String
  appliedAt DateTime
  status    String   @default("pending")
  resume    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hiringId String @db.ObjectId
  hiring   Hiring @relation(fields: [hiringId], references: [id])

  reviews CandidateReview[]

  @@index([hiringId])
  @@index([status])
  @@map("candidates")
}

model CandidateReview {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  feedback  String
  rating    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id])
  candidateId String    @db.ObjectId
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  @@index([userId])
  @@index([candidateId])
  @@map("candidate_reviews")
}
