{
  "$schema": "https://swc.rs/schema.json",
  "sourceMaps": true,
  "module": {
    "type": "commonjs"
  },
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "logs",
    "keys",
    ".warmup",
    ".nyc_output",
    "src/metadata.ts",
    "swagger.json",
    "generated"
  ],
  "jsc": {
    "baseUrl": "./",
    "paths": {
      "src/*": ["src/*"]
    },
    "target": "esnext",
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    }
  },
  "minify": false
}
