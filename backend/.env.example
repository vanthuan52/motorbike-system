# For app
NODE_ENV=development
APP_NAME="nestjs-mongodb-motorbike"
APP_TIMEZONE="Asia/Ho_Chi_Minh"
APP_LANGUAGE=en

HOME_URL=https://example.id
HOME_NAME=Nestjs

HTTP_HOST=localhost
HTTP_PORT=5300

URL_VERSIONING_ENABLE=true
URL_VERSION=1

GLOBAL_PREFIX="/api"
MIDDLEWARE_CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080,http://192.168.1.230:8080,http://192.168.1.1:8080

LOGGER_ENABLE=true
LOGGER_LEVEL=debug
LOGGER_INTO_FILE=true
LOGGER_PRETTIER=true
LOGGER_AUTO=false

JOB_ENABLE=false

# For database
DATABASE_URL=mongodb://mongo:changeme@127.0.0.1:27017/motorbike_system
DATABASE_HOST=mongodb://127.0.0.1:27017
DATABASE_NAME=motorbike_system
DATABASE_USERNAME=mongo
DATABASE_PASSWORD=changeme
DATABASE_DEBUG=true # True for development

AUTH_JWT_ISSUER=https://example.id
AUTH_JWT_AUDIENCE=MotorbikeSystemClient

AUTH_JWT_ACCESS_TOKEN_JWKS_URI=http://localhost:3011/.well-known/access-jwks.json
AUTH_JWT_ACCESS_TOKEN_KID=902a681bb00106d90bd65d53f0c6bacd
AUTH_JWT_ACCESS_TOKEN_PRIVATE_KEY=qwerty1234567890
AUTH_JWT_ACCESS_TOKEN_PUBLIC_KEY=qwerty1234567890
AUTH_JWT_ACCESS_TOKEN_EXPIRED=1d

AUTH_JWT_REFRESH_TOKEN_JWKS_URI=http://localhost:3011/.well-known/refresh-jwks.json
AUTH_JWT_REFRESH_TOKEN_KID=58c7c9eb0309dc46a696f488855f1b85
AUTH_JWT_REFRESH_TOKEN_PRIVATE_KEY=qwerty1234567890
AUTH_JWT_REFRESH_TOKEN_PUBLIC_KEY=qwerty1234567890
AUTH_JWT_REFRESH_TOKEN_EXPIRED=30d

AUTH_TWO_FACTOR_ISSUER=ACKNestJsTwoFactor
AUTH_TWO_FACTOR_ENCRYPTION_KEY=qwerty1234567890

AUTH_SOCIAL_GOOGLE_CLIENT_ID=
AUTH_SOCIAL_GOOGLE_CLIENT_SECRET=

AUTH_SOCIAL_APPLE_CLIENT_ID=
AUTH_SOCIAL_APPLE_SIGN_IN_CLIENT_ID=

# S3 Storage Configuration (shared for AWS S3 and MinIO)
AWS_S3_PUBLIC_BUCKET=app-public-files
AWS_S3_PRIVATE_BUCKET=app-private-files
AWS_S3_TEMP_BUCKET=app-temp-processing
AWS_S3_IAM_CREDENTIAL_KEY=
AWS_S3_IAM_CREDENTIAL_SECRET=
AWS_S3_IAM_ARN=

# AWS S3 (for Production - when NODE_ENV=production)
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_REGION=ap-southeast-3
AWS_S3_CDN=

# MinIO (for Development/Staging - when NODE_ENV != production)
MINIO_ACCESS_KEY=app-backend-user
MINIO_SECRET_KEY=changeme
MINIO_ENDPOINT=http://localhost:39000

AWS_SES_CREDENTIAL_KEY=
AWS_SES_CREDENTIAL_SECRET=
AWS_SES_REGION=ap-southeast-3

CACHE_REDIS_URL=redis://localhost:6379/0

QUEUE_REDIS_URL=redis://localhost:6379/1

