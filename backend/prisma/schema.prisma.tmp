enum PolicyAction {
  MANAGE
  READ
  CREATE
  UPDATE
  DELETE

  @@map("policy_action")
}

enum PolicySubject {
  ALL
  API_KEY
  ROLE
  USER
  AUTH
  SESSION
  ACTIVITY_LOG
  PASSWORD_HISTORY
  TERM_POLICY
  FEATURE_FLAG
  NOTIFICATION
  SETTING
  VERIFICATION
  VEHICLE_BRAND
  VEHICLE_MODEL
  VEHICLE_SERVICE
  SERVICE_CATEGORY
  SERVICE_PRICE
  SERVICE_CHECKLIST
  PART
  PART_TYPE
  APPOINTMENT
  STORE
  CARE_AREA
  CARE_RECORD
  CARE_RECORD_CHECKLIST
  CARE_RECORD_CONDITION
  CARE_RECORD_ITEM
  CARE_RECORD_MEDIA
  CARE_RECORD_SERVICE
  HIRING
  CANDIDATE
  MESSAGE
  CONVERSATION
  USER_VEHICLE

  @@map("policy_subject")
}
