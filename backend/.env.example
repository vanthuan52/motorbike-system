AUTH_SOCIAL_GOOGLE_CLIENT_ID=
AUTH_SOCIAL_GOOGLE_CLIENT_SECRET=

AUTH_SOCIAL_APPLE_CLIENT_ID=
AUTH_SOCIAL_APPLE_SIGN_IN_CLIENT_ID=

# MinIO root credentials (admin account — docker-compose only)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# S3 Storage Configuration
# MinIO mode for development: set STORAGE_ENDPOINT to local MinIO instance
# Do not set STORAGE_ENDPOINT means we use aws s3
STORAGE_ENDPOINT=http://localhost:39000
STORAGE_FORCE_PATH_STYLE=true

AWS_S3_PUBLIC_BUCKET=app-public-files
AWS_S3_PRIVATE_BUCKET=app-private-files
AWS_S3_TEMP_BUCKET=app-temp-processing

AWS_S3_IAM_CREDENTIAL_KEY=app-backend-user
AWS_S3_IAM_CREDENTIAL_SECRET=changeme
AWS_S3_IAM_ARN=
AWS_S3_REGION=us-east-1

AWS_SES_CREDENTIAL_KEY=
AWS_SES_CREDENTIAL_SECRET=
AWS_SES_REGION=ap-southeast-3

CACHE_REDIS_URL=redis://localhost:6379/0

QUEUE_REDIS_URL=redis://localhost:6379/1

# SENTRY
SENTRY_DSN=

# Bull Board Dashboard (docker-compose only)
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=changeme
