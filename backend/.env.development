CORS_ALLOWED_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080,http://192.168.1.230:8080,http://192.168.1.1:8080

URL_VERSIONING_ENABLE=true
URL_VERSION=1

