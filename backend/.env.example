# For app
NODE_ENV=development
APP_NAME="nestjs-mongodb-motorbike"
APP_TIMEZONE="Asia/Ho_Chi_Minh"
APP_LANGUAGE=en

HOME_URL=https://example.id
HOME_NAME=Nestjs

HTTP_HOST=0.0.0.0
HTTP_PORT=5300

URL_VERSIONING_ENABLE=true
URL_VERSION=1

GLOBAL_PREFIX="/api"
MIDDLEWARE_CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080,http://192.168.1.230:8080,http://192.168.1.1:8080

LOGGER_ENABLE=false
LOGGER_LEVEL=debug
LOGGER_INTO_FILE=true
LOGGER_PRETTIER=true
LOGGER_AUTO=false

JOB_ENABLE=false

# For database
DATABASE_URL=
DATABASE_HOST=mongodb://127.0.0.1:27017
DATABASE_NAME=motorbike_system
DATABASE_USERNAME=mongo
DATABASE_PASSWORD=changeme
DATABASE_DEBUG=true # True for development

AUTH_JWT_ISSUER=https://example.id
AUTH_JWT_AUDIENCE=MotorbikeSystemClient

