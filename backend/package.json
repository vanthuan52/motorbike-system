{
  "name": "nestjs-motorbike-system",
  "version": "0.0.1",
  "description": "Motorbike system application built on NestJs",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "vanthuan52",
    "email": "charlesdang.252@gmail.com"
  },
  "scripts": {
    "generate:keys": "npx ts-node scripts/generate-keys.ts",
    "format": "prettier --write '{src,test}/**/*.{ts,json,yml,yaml}' && prettier --write '*.{ts,json,yml,yaml,mjs}'",
    "deadcode": "ts-prune --project tsconfig.json --skip *.json --skip generated/* | grep -v 'used in module'",
    "spell": "cspell lint --config cspell.json '{src,test}/**/*.ts' --color --gitignore --no-must-find-files --no-summary --no-progress || true",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "package:upgrade": "npx npm-check-updates -u",
    "package:check": "npx npm-check-updates -i",
    "lint": "eslint",
    "lint:staged": "lint-staged",
    "lint:fix": "eslint --fix",
    "build": "NODE_ENV=production nest build application --config nest-cli.json",
    "build:dev": "NODE_ENV=production nest build application --config nest-cli.json --watch",
    "start": "NODE_ENV=development nest start application --config nest-cli.json",
    "start:dev": "NODE_ENV=development nest start application --watch --config nest-cli.json",
    "start:prod": "NODE_ENV=production node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "pm2:dev": "nest start --env development",
    "pm2:prod": "node dist/main --env production",
    "migrate:fresh": "NODE_ENV=development npm run migrate:remove && npm run migrate:seed",
    "migrate:seed": "NODE_ENV=development nestjs-command seed:role && nestjs-command seed:user && nestjs-command seed:part-type && nestjs-command seed:hiring && nestjs-command seed:store",
    "migrate:seed:care-area": "nestjs-command seed:care-area && nestjs-command seed:service-checklist",
    "migrate:remove": "NODE_ENV=development nestjs-command remove:user && nestjs-command remove:role && nestjs-command remove:part-type && nestjs-command remove:hiring  && nestjs-command remove:store && nestjs-command remove:care-area && nestjs-command remove:service-checklist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/client-ses": "^3.958.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@casl/ability": "^6.7.5",
    "@faker-js/faker": "^10.1.0",
    "@keyv/redis": "^5.1.5",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.10",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.10",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.10",
    "@nestjs/platform-socket.io": "^11.1.10",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.10",
    "@sentry/nestjs": "^10.32.1",
    "@sentry/node": "^10.32.1",
    "@smithy/types": "^4.11.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.66.3",
    "cache-manager": "^7.2.7",
    "case": "^1.6.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "crypto-js": "^4.2.0",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "lodash": "^4.17.21",
    "luxon": "^3.7.2",
    "mime": "^4.1.0",
    "mongodb": "^6.21.0",
    "mongoose": "^8.19.3",
    "ms": "^2.1.3",
    "nest-commander": "^3.20.1",
    "nestjs-command": "^3.1.5",
    "nestjs-i18n": "^10.6.0",
    "nestjs-pino": "^4.5.0",
    "nestjs-real-ip": "^3.0.1",
    "otplib": "^13.3.0",
    "papaparse": "^5.5.3",
    "passport-jwt": "^4.0.1",
    "path": "^0.12.7",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "response-time": "^2.3.4",
    "rotating-file-stream": "^3.2.7",
    "rxjs": "^7.8.2",
    "slugify": "^1.6.6",
    "ua-parser-js": "^2.0.7",
    "uuid": "^13.0.0",
    "verify-apple-id-token": "^3.1.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.10",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.7",
    "@types/bcrypt": "^6.0.0",
    "@types/bytes": "^3.1.5",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.21",
    "@types/luxon": "^3.7.1",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/papaparse": "^5.5.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/response-time": "^2.3.9",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint",
      "stop-only --file"
    ],
    "*.{json,yaml}": [
      "prettier --write"
    ]
  }
}
